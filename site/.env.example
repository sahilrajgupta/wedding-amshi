# Copy this file to .env and fill in real values.
# None of these are secret — they ship inside the client bundle regardless —
# this file just makes local/prod overrides easy to manage.

# WhatsApp numbers the RSVP button messages, digits only with country code, no + or spaces.
# Example: 919876543210
# RSVP is routed to the matching number by the guest's Team Ladki/Ladke pick;
# the bride's number is the fallback when no team has been picked yet.
VITE_WHATSAPP_BRIDE=
VITE_WHATSAPP_GROOM=

# RSVP deadline shown to guests, ISO date (YYYY-MM-DD).
VITE_RSVP_DEADLINE=2026-07-20

# Google Maps *directions* link for the venue (Mango Bloom River Resort, Jim Corbett).
# Defaults to the couple's real map link already — only override if it changes.
VITE_VENUE_MAPS_LINK=https://maps.app.goo.gl/BGt7gv9gKCA6Kapk6

# Google Apps Script Web App /exec URL — see SETUP.md for how to deploy it.
VITE_APPS_SCRIPT_URL=
