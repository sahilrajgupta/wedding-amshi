# Copy this file to .env and fill in real values.
# None of these are secret — they ship inside the client bundle regardless —
# this file just makes local/prod overrides easy to manage.

# WhatsApp number the RSVP button messages, digits only with country code, no + or spaces.
# Example: 919876543210
VITE_WHATSAPP_PHONE=

# RSVP deadline shown to guests, ISO date (YYYY-MM-DD).
VITE_RSVP_DEADLINE=2026-12-20

# Google Maps *directions* link for the venue (Mango Bloom Riverview Resort, Jim Corbett).
# Prefer a deep link that starts turn-by-turn directions, e.g.:
# https://www.google.com/maps/dir/?api=1&destination=<place name or lat,lng>
VITE_VENUE_MAPS_LINK=

# Google Apps Script Web App /exec URL — see SETUP.md for how to deploy it.
VITE_APPS_SCRIPT_URL=
